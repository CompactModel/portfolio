# Application
APP_ENV=prod
APP_SECRET=change-this-to-a-random-32-character-string

# Database — Railway MySQL plugin provides this automatically
DATABASE_URL=mysql://user:password@host:3306/dbname

# CORS — set to your Vercel frontend URL (or keep * for public API)
CORS_ALLOW_ORIGIN=^https://your-frontend.vercel.app$

# Admin account auto-created on first deploy if user table is empty
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-after-first-login
